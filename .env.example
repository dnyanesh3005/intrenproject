# ─── Email Configuration ────────────────────────────────────────────────────
# Your Gmail address
GMAIL_ADDRESS=your_email@gmail.com

# Gmail App Password (NOT your real password)
# Get it from: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Tracking Server URL ────────────────────────────────────────────────────
# The public URL where tracking_server.py is running
# For local dev with ngrok: https://abc123.ngrok-free.app
# For Streamlit Cloud: leave as localhost for now
TRACKING_BASE_URL=http://localhost:8000

# ─── Redirect URL ────────────────────────────────────────────────────────────
# The URL users are redirected to when they click the email link
REDIRECT_URL=https://yourwebsite.com

# ─── AI Classification (Optional) ────────────────────────────────────────────
# Get a free Gemini API key from: https://makersuite.google.com/app/apikey
# Leave blank to use keyword-based classification instead
GEMINI_API_KEY=
